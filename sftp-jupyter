HOST = "s-c54c5ab6ec2d429b8.server.transfer.us-west-2.amazonaws.com"
PORT = 22
USERNAME = "你的用户名" # 图片里是 a2.wang
PRIVATE_KEY_PATH = "你的私钥文件路径" # 例如 Mac: "/Users/你的名字/.ssh/id_rsa" 或 Windows: "C:/Users/你的名字/.ssh/id_rsa"
LOCAL_DOWNLOAD_PATH = "你本地想要下载的路径"
REMOTE_FILE_PATH = "服务器上的目标路径"

Cell 2:
import paramiko # 图片中缺失了这行引入代码的步骤，必须加上

ssh_client = paramiko.SSHClient()
ssh_client.set_missing_host_key_policy(paramiko.AutoAddPolicy())

ssh_client.connect(hostname=HOST, port=PORT, username=USERNAME, key_filename=PRIVATE_KEY_PATH)
sftp_client = ssh_client.open_sftp()
print("SFTP session opened.")

